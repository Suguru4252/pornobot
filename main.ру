    message_id = call.message.message_id
    
    if call.data == "char_girl":
        user_character[chat_id] = 'girl'
        bot.edit_message_text(
            "✅ Ты выбрал *Развратную девушку*\n"
            "Она горяча, игрива и всегда готова удовлетворить твои фантазии.\n"
